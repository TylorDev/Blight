{
  "name": "blight",
  "version": "1.0.0",
  "private": true,
  "description": "Blight inventory and XL ticket accounting desktop app.",
  "author": "Tytordev",
  "repository": {
    "type": "git",
    "url": "https://github.com/TylorDev/blight.git"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:raw": "electron-vite dev",
    "build": "npm run prisma:generate && tsc --noEmit && electron-vite build",
    "dist:win": "npm run build && electron-builder --win",
    "pack:win": "npm run build && electron-builder --win --dir",
    "postinstall": "prisma generate",
    "test": "vitest run --configLoader runner",
    "test:generate": "npm run prisma:generate && npm test",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:init": "tsx prisma/init.ts",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.8.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.17.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.2.1",
    "electron-builder": "^26.15.2",
    "electron-vite": "^3.1.0",
    "prisma": "^6.8.2",
    "sass": "^1.89.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.tytordev.blight",
    "productName": "Blight",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/pack-prisma.cjs",
    "files": [
      "out/**",
      "src/Resources/**",
      "node_modules/@prisma/client/**",
      "node_modules/.prisma/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@prisma/client/**",
      "node_modules/.prisma/client/query_engine-*.node"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blight"
    }
  }
}
